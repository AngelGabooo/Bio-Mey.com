{
  "version": 2,
  "builds": [
    {
      "src": "api/voice.js",
      "use": "@vercel/node"
    },
    {
      "src": "dist/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/voice", "destination": "/api/voice.js" },
    { "source": "/process-voice", "destination": "/api/voice.js" },
    { "source": "/health", "destination": "/api/voice.js" },
    { "source": "/test", "destination": "/api/voice.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}